# Compiled objects / shared libraries (regenerated on build)
*.o
*.so
*.dll
*.a
*.dylib

# R session / history / data
.Rhistory
.RData
.Rapp.history
.Ruserdata
*.rds

# RStudio
.Rproj.user/

# R CMD build / check artifacts
*.tar.gz
*.Rcheck/
/..Rcheck/

# OS cruft
.DS_Store
Thumbs.db

# Claude Code session/tooling config (local only, not part of the package)
.claude/

# Generated validation outputs (scripts are tracked; results are regenerable)
dev/validation/results/

# Vignette / pkgdown build output
inst/doc/
docs/
.positai

# Internal planning/review notes (kept local, not published)
REASSESSMENT.md

# Generated LaTeX build artifacts (manuscript source doc/main.tex and doc/references.bib
# are tracked; everything below is regenerated by pdflatex/bibtex)
doc/*.aux
doc/*.bbl
doc/*.blg
doc/*.log
doc/*.out
doc/*.toc
doc/*.lof
doc/*.lot
doc/*.fls
doc/*.fdb_latexmk
doc/*.synctex.gz
doc/*.pdf
